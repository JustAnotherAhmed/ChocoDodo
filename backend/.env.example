# =====================================================
# ChocoDoDo Backend — Environment Variables
# Copy this file to ".env" and fill in your real keys.
# NEVER commit .env to git (it's already in .gitignore).
# =====================================================

# ---------- Server ----------
PORT=4242
NODE_ENV=development

# Where the frontend is served from (used to build email/verify/reset links).
FRONTEND_URL=http://localhost:4242

# ---------- Pricing ----------
# 3-letter ISO code. ChocoDoDo operates in Egypt → use "egp".
CURRENCY=egp

# Flat delivery fee in piastres (1 EGP = 100 piastres). 30 EGP default.
DELIVERY_MINOR_UNITS=3000

# Tax rate (decimal). Set 0 unless VAT-registered (then 0.14).
TAX_RATE=0

# Required deposit percentage. Customers can pay this much OR 100% in full.
DEPOSIT_PCT=50

# ---------- EMAIL (optional but recommended) ----------
# Pick ONE option. See SETUP_NOTIFICATIONS.md for full instructions.
#
# OPTION A — Resend (recommended, free 3,000/month, no 2FA)
#   Sign up at https://resend.com → API Keys → Create
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx
#   EMAIL_FROM=ChocoDoDo <onboarding@resend.dev>
#
# OPTION B — Gmail App Password (free ~500/day, requires 2FA)
#   https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=yourgmail@gmail.com
#   SMTP_PASS=16-char-app-password
#   EMAIL_FROM=ChocoDoDo <yourgmail@gmail.com>
#
# If you leave SMTP_USER/SMTP_PASS blank, the server logs emails to the
# console instead — useful in dev so you can copy the verify/reset link
# from the terminal without setting up email.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ChocoDoDo <onboarding@resend.dev>"

# Where order copies should go (your own inbox).
EMAIL_TO_OWNER=

# ---------- ADMIN ----------
# Legacy quick-key for the simple /admin/orders HTML view.
# The proper admin panel uses real login (see ADMIN_EMAIL below).
ADMIN_KEY=change-me-to-something-long-and-random

# ---------- ADMIN SEED ----------
# On first boot, the server creates an admin account with these creds.
# Password is bcrypt-hashed before storage; plaintext is NEVER kept in the DB.
# After first successful login, you can REMOVE these env vars or change
# the password from the admin panel.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ---------- AUTH ----------
# Long, random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex-string

# Cookie domain (leave blank for same-site dev). Production: .chocododo.com
COOKIE_DOMAIN=

# Set to "true" in production (HTTPS) to force secure cookies.
COOKIE_SECURE=false

# ---------- TELEGRAM (owner alerts on phone) ----------
# Create a bot via @BotFather, send it any message, then GET
# https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bot @username so customers can deep-link to it from the verify page
# (find it in BotFather or in your bot's profile — without the @).
TELEGRAM_BOT_USERNAME=

# ---------- WHATSAPP (click-to-chat for customers + payment instructions) ----------
# E.164 with country code, NO + and NO spaces.
# Egypt: country code 20 + 10-digit mobile (drop the leading 0).
# Example: +20 101 234 5678  →  201012345678
WHATSAPP_OWNER_NUMBER=

# ---------- WHATSAPP via CallMeBot (optional, owner pings on phone) ----------
# Free WhatsApp pings on your phone for each new order. See SETUP_NOTIFICATIONS.md.
CALLMEBOT_PHONE=
CALLMEBOT_API_KEY=
